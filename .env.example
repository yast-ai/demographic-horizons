# =============================================================================
# LOCAL DEVELOPMENT (.env.local)
# Auto-written by `npx convex dev` for Convex + WorkOS AuthKit.
# =============================================================================
CONVEX_DEPLOYMENT=dev:robust-guineapig-942
VITE_CONVEX_URL=https://robust-guineapig-942.convex.cloud
VITE_CONVEX_SITE_URL=https://robust-guineapig-942.convex.site

# WorkOS (TanStack Start server + client) — provisioned by Convex AuthKit
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URI=http://localhost:3000/callback
WORKOS_COOKIE_PASSWORD=
VITE_WORKOS_CLIENT_ID=
VITE_WORKOS_REDIRECT_URI=http://localhost:3000/callback

# PostHog (client-side analytics)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# =============================================================================
# CONVEX DEV DEPLOYMENT (npx convex env set)
# Backend secrets only — NOT in Vercel
# =============================================================================
# AI_GATEWAY_API_KEY=   # Vercel AI Gateway for AI policy briefs
# WORKOS_CLIENT_ID      # Auto-provisioned by AuthKit

# =============================================================================
# CONVEX PROD DEPLOYMENT (npx convex env set --prod)
# Backend secrets only — NOT in Vercel (except during build for AuthKit)
# =============================================================================
# AI_GATEWAY_API_KEY=
# WORKOS_CLIENT_ID      # Auto-provisioned by AuthKit on deploy

# =============================================================================
# VERCEL PRODUCTION ONLY
# Set via: vercel env add <NAME> production
# =============================================================================
# CONVEX_DEPLOY_KEY=              # prod deploy key from `npx convex deployment token create`
# VITE_CONVEX_URL=                # https://<prod>.convex.cloud
# WORKOS_CLIENT_ID=               # prod WorkOS client (from Convex prod env)
# WORKOS_API_KEY=                 # prod WorkOS API key (from Convex prod env)
# WORKOS_REDIRECT_URI=            # https://<domain>/callback
# WORKOS_COOKIE_PASSWORD=         # 32+ char secret for session cookies
# VITE_WORKOS_CLIENT_ID=
# VITE_WORKOS_REDIRECT_URI=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
